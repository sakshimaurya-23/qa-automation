<MultiApi>
	<API Name="getShipmentList">
		<Input>
			<Shipment OrderNo="${OrderNo}" ShipNode="" />
		</Input>
		<Template>
			<ShipmentList>
				<Shipment OrderNo="${OrderNo}" ShipNode="" Status="">
					<ShipmentLines>
						<ShipmentLine OrderNo="${OrderNo}" Quantity="" ShortageQty=""/>
					</ShipmentLines>
				</Shipment>
			</ShipmentList>
		</Template>
	</API>
</MultiApi>
