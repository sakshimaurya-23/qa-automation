<MultiApi>
	<API Name="getShipmentList">
		<Input>
			<Shipment ShipmentNo="${ShipmentNo_Extracted}" EnterpriseCode="CT_Furniture_INC" />
		</Input>
		<Template>
			<ShipmentList>
				<Shipment ShipmentNo="${ShipmentNo_Extracted}" ShipNode="" Status="">
					<ShipmentLines>
						<ShipmentLine OrderNo="${OrderNo}" Quantity="" ShortageQty=""/>
					</ShipmentLines>
				</Shipment>
			</ShipmentList>
		</Template>
	</API>
</MultiApi>
