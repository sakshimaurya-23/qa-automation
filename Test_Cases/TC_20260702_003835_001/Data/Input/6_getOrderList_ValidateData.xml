<MultiApi>
	<API Name="getOrderList">
		<Input>
			<Order OrderNo="${OrderNo}" DocumentType="" OrganizationCode="" />
		</Input>
		<Template>
			<OrderList>
				<Order OrderNo="${OrderNo}" OrganizationCode="" UnitOfMeasure="" MinOrderStatus="">
				<OrderLines>
				<OrderLine OrderedQty="1" >
					<ItemDetails ItemID="${RandomId}" />
				</OrderLine>
				</OrderLines>
				</Order>
			</OrderList>
		</Template>
	</API>
</MultiApi>