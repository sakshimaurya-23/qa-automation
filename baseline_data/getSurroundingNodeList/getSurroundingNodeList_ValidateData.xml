<MultiApi>
	<API Name="getATPForNearestStores">
		<Input>
			<Promise ZipCode="${ZipCode}" ItemID="${RandomId}" LineId="1" ProductClass="GOOD" UnitOfMeasure="EACH" />
		</Input>
		<Template>
			<Promise EnterpriseCode="CT_Furniture_INC" OrganizationCode="CT_Furniture_INC">
				<PromiseLines>
					<PromiseLine ItemID="${RandomId}" LineId="1" ProductClass="GOOD" UnitOfMeasure="EACH">
						<Availability>
							<AvailableInventory AvailableOnhandQuantity="" AvailableQuantity="">
								<ShipNodeAvailableInventory>
									<Inventory AvailableOnhandQuantity="" AvailableQuantity="" DistanceFromShipToAddress="" Node="">
										<ShipNodePersonInfo>
											<ShipNodePersonInfo AddressLine1="" City="" Country="" Latitude="" Longitude="" MobilePhone="" NodeType="" State="" ZipCode=""/>
										</ShipNodePersonInfo>
									</Inventory>
								</ShipNodeAvailableInventory>
							</AvailableInventory>
						</Availability>
					</PromiseLine>
				</PromiseLines>
			</Promise>
		</Template>
	</API>
</MultiApi>
